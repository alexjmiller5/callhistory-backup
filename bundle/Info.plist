<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.alexmiller.callhistory-backup</string>

    <key>CFBundleName</key>
    <string>CallHistoryBackup</string>

    <key>CFBundleDisplayName</key>
    <string>Call History Backup</string>

    <!-- The main executable IS the backup script (Contents/MacOS/callhistory-backup),
